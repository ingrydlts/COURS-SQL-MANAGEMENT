<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SQL Data Management — Cours Interactif</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;1,500&display=swap" rel="stylesheet">
<script>
  // All functions called via inline onclick must be defined here (before body renders)
  function show(id) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.nav-pill').forEach(p => p.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    const map = { home: 0, mcd: 1, mld: 2, mpd: 3, sql: 4 };
    const pills = document.querySelectorAll('.nav-pill');
    if (pills[map[id]]) pills[map[id]].classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }
  // Stubs — real implementations are in the bottom script block after DOM is built
  function startFlashcards(m) { window._pendingFC = m; }
  function closeFlashcards()  { var o=document.getElementById('fcOverlay'); if(o){o.classList.remove('visible'); document.body.style.overflow='';} }
  function flipCard()         { var c=document.getElementById('fcCard'); if(c){c.classList.toggle('flipped'); if(c.classList.contains('flipped') && window._fcMarkSeen) window._fcMarkSeen();} }
  function fcNext()           { if(window._fcNext) window._fcNext(); }
  function fcPrev()           { if(window._fcPrev) window._fcPrev(); }
  function restartFlashcards(){ if(window._fcRestart) window._fcRestart(); }
  function closeKwModal()     { var m=document.getElementById('kwModal'); if(m){m.classList.remove('visible'); document.body.style.overflow='';} }
  function closeModal(e)      { if(e.target===document.getElementById('kwModal')) closeKwModal(); }
</script>
<style>
  :root {
    --bg: #f5f4f0;
    --surface: #eceae4;
    --card: #ffffff;
    --border: #d8d5cc;
    --accent1: #4f46e5;
    --accent2: #e0405e;
    --accent3: #0d9e7e;
    --accent4: #c97a1a;
    --text: #1a1a2e;
    --muted: #6b6880;
    --code-bg: #f0eee8;
    --code-text: #1a1a2e;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* NAVIGATION */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(245,244,240,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .nav-logo {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .nav-pills {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .nav-pill {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    padding: 0.3rem 0.7rem;
    border-radius: 100px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-pill:hover, .nav-pill.active {
    border-color: var(--accent1);
    color: var(--accent1);
    background: rgba(79,70,229,0.08);
  }

  /* MAIN */
  main {
    padding-top: 60px;
  }

  /* SECTIONS */
  .section {
    display: none;
    min-height: calc(100vh - 60px);
    padding: 3rem 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section.active {
    display: block;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 5rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -100px; left: 50%;
    transform: translateX(-50%);
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(79,70,229,0.07) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero-tag {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent3);
    border: 1px solid var(--accent3);
    padding: 0.3rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  h1.hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--accent1), var(--accent2));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    color: var(--muted);
    font-size: 1.1rem;
    max-width: 520px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  .modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
    margin-top: 3rem;
    text-align: left;
  }

  .module-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    cursor: pointer;
    transition: all 0.25s;
    position: relative;
    overflow: hidden;
  }

  .module-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--card-accent);
    transition: opacity 0.2s;
  }

  .module-card:hover {
    border-color: var(--card-accent);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
  }

  .module-num {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--muted);
    margin-bottom: 0.7rem;
    letter-spacing: 0.1em;
  }

  .module-title {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.4rem;
    letter-spacing: -0.01em;
  }

  .module-desc {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.5;
  }

  /* SECTION HEADERS */
  .section-header {
    margin-bottom: 2.5rem;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--accent);
    border: 1px solid currentColor;
    padding: 0.25rem 0.8rem;
    border-radius: 100px;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  h2.section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 600;
    line-height: 1.15;
    margin-bottom: 0.7rem;
    letter-spacing: -0.01em;
  }

  .section-intro {
    color: var(--muted);
    font-size: 1rem;
    max-width: 640px;
    line-height: 1.65;
  }

  /* CARDS */
  .card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .card-title {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    letter-spacing: -0.01em;
  }

  /* CONCEPT GRID */
  .concept-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1rem;
    margin: 1.5rem 0;
  }

  .concept-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem;
    border-left: 3px solid var(--c, var(--accent1));
  }

  .concept-card h4 {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 0.85rem;
    margin-bottom: 0.5rem;
    color: var(--c, var(--accent1));
    letter-spacing: -0.01em;
  }

  .concept-card p {
    font-size: 0.85rem;
    color: var(--muted);
    line-height: 1.55;
  }

  /* DIAGRAM BOXES */
  .diagram-container {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }

  .diagram-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin: 1rem 0;
  }

  .entity-box {
    background: var(--card);
    border: 2px solid var(--accent1);
    border-radius: 8px;
    min-width: 140px;
    overflow: hidden;
    font-size: 0.8rem;
  }

  .entity-name {
    background: var(--accent1);
    color: white;
    font-family: 'Space Mono', monospace;
    font-weight: 700;
    font-size: 0.75rem;
    padding: 0.4rem 0.8rem;
    text-align: center;
    letter-spacing: 0.05em;
  }

  .entity-attrs {
    padding: 0.5rem 0.8rem;
    line-height: 1.7;
    color: var(--muted);
  }

  .entity-attrs span.pk {
    color: var(--accent4);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .entity-attrs span.fk {
    color: var(--accent2);
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .entity-attrs span.attr {
    font-size: 0.78rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .relation-box {
    background: rgba(224,64,94,0.08);
    border: 2px solid var(--accent2);
    border-radius: 8px;
    padding: 0.6rem 1rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--accent2);
    text-align: center;
    white-space: nowrap;
  }

  .cardinality {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent4);
    padding: 0.2rem 0.5rem;
    background: rgba(201,122,26,0.1);
    border-radius: 4px;
  }

  .arrow {
    color: var(--border);
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  /* CODE BLOCKS */
  pre, code {
    font-family: 'Space Mono', monospace;
  }

  .code-block {
    background: var(--code-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.2rem 1.5rem;
    margin: 1rem 0;
    overflow-x: auto;
    font-size: 0.82rem;
    line-height: 1.8;
    position: relative;
    color: var(--code-text);
  }

  .code-label {
    position: absolute;
    top: -1px; right: 12px;
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    background: var(--accent3);
    color: var(--bg);
    padding: 0.2rem 0.6rem;
    border-radius: 0 0 6px 6px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .kw { color: #c0392b; font-weight: 700; }
  .fn { color: #6f42c1; font-weight: 600; }
  .str { color: #0d7a5f; }
  .cm { color: #888; font-style: italic; }
  .num { color: #0550ae; }
  .type { color: #b35800; font-weight: 600; }

  /* TABLE */
  .sql-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    margin: 1rem 0;
  }

  .sql-table th {
    background: var(--accent1);
    color: white;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    padding: 0.6rem 1rem;
    text-align: left;
    letter-spacing: 0.05em;
  }

  .sql-table td {
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--muted);
  }

  .sql-table tr:hover td { background: rgba(255,255,255,0.03); }

  /* RULES TABLE */
  .rules-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
    margin: 1rem 0;
    border-radius: 12px;
    overflow: hidden;
  }

  .rules-table th {
    background: var(--surface);
    color: var(--accent3);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    padding: 0.8rem 1.2rem;
    text-align: left;
    border-bottom: 2px solid var(--border);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .rules-table td {
    padding: 0.7rem 1.2rem;
    border-bottom: 1px solid var(--border);
    background: var(--card);
    line-height: 1.5;
  }

  .rules-table td:first-child {
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    color: var(--accent4);
    font-weight: 700;
    white-space: nowrap;
  }

  .rules-table td:nth-child(2) { color: var(--text); }
  .rules-table td:nth-child(3) { color: var(--muted); font-size: 0.8rem; }

  /* REVIEW SECTION */
  .review-section {
    background: linear-gradient(135deg, rgba(79,70,229,0.05), rgba(224,64,94,0.04));
    border: 1px solid rgba(79,70,229,0.2);
    border-radius: 20px;
    padding: 2rem;
    margin: 2.5rem 0;
  }

  .review-header {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 1.5rem;
  }

  .review-icon {
    width: 36px; height: 36px;
    background: var(--accent1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .review-header h3 {
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: -0.01em;
  }

  /* KEYWORDS */
  .keywords-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin: 1rem 0 1.5rem;
  }

  .keyword {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    padding: 0.35rem 0.8rem;
    border-radius: 8px;
    letter-spacing: 0.04em;
    border: 1px solid currentColor;
  }

  /* EXERCISE */
  .exercise {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.3rem;
    margin: 1rem 0;
  }

  .exercise-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.65rem;
    color: var(--accent4);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 0.6rem;
  }

  .exercise p {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text);
    margin-bottom: 0.8rem;
  }

  /* DROPDOWN ANSWER */
  details.answer {
    margin-top: 0.8rem;
  }

  details.answer summary {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--accent3);
    padding: 0.5rem 0.8rem;
    background: rgba(13,158,126,0.07);
    border: 1px solid rgba(13,158,126,0.2);
    border-radius: 8px;
    list-style: none;
    transition: all 0.2s;
    user-select: none;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  details.answer summary::-webkit-details-marker { display: none; }

  details.answer summary:hover {
    background: rgba(13,158,126,0.12);
  }

  details.answer[open] summary {
    background: rgba(13,158,126,0.1);
    border-color: var(--accent3);
    border-radius: 8px 8px 0 0;
  }

  .answer-content {
    background: #f7f9f4;
    border: 1px solid rgba(13,158,126,0.15);
    border-top: none;
    border-radius: 0 0 8px 8px;
    padding: 1.4rem;
    font-size: 0.86rem;
    line-height: 1.7;
    color: var(--text);
  }

  .answer-content strong { color: #0d7a5f; }

  /* Visual answer tables */
  .ans-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0.8rem 0;
    font-size: 0.82rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .ans-table th {
    background: #e8f4f0;
    color: #0d7a5f;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    padding: 0.6rem 1rem;
    text-align: left;
    border-bottom: 2px solid #b8ddd5;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .ans-table td {
    padding: 0.55rem 1rem;
    border-bottom: 1px solid #e8e6e0;
    vertical-align: top;
    color: var(--text);
    background: white;
  }
  .ans-table tr:last-child td { border-bottom: none; }
  .ans-table td.pk { color: #b35800; font-family: 'Space Mono', monospace; font-size: 0.75rem; font-weight: 700; }
  .ans-table td.fk { color: #c0392b; font-family: 'Space Mono', monospace; font-size: 0.75rem; }
  .ans-table td.attr { color: var(--muted); font-size: 0.8rem; }
  .ans-table td.rule { color: #4f46e5; font-size: 0.78rem; font-style: italic; }

  /* MLD schema visual */
  .mld-schema {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0.8rem 0;
  }
  .mld-table-box {
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .mld-table-name {
    background: #4f46e5;
    color: white;
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.4rem 0.9rem;
    letter-spacing: 0.06em;
  }
  .mld-table-name.green { background: #0d9e7e; }
  .mld-table-name.pink  { background: #e0405e; }
  .mld-table-name.orange{ background: #c97a1a; }
  .mld-cols {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    padding: 0.6rem 0.9rem;
  }
  .mld-col {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    padding: 0.2rem 0.5rem;
    border-radius: 5px;
    background: #f0eee8;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .mld-col.is-pk { background: #fff3e0; color: #b35800; border-color: #f0c070; font-weight: 700; }
  .mld-col.is-fk { background: #fdecea; color: #c0392b; border-color: #f5b8b0; }
  .mld-col.is-pkfk { background: #fce4ec; color: #c0392b; border-color: #f48fb1; font-weight: 700; }
  .mld-rule-note {
    font-size: 0.78rem;
    color: #4f46e5;
    font-style: italic;
    padding: 0.3rem 0.9rem 0.6rem;
  }

  /* Answer code block (light) */
  .ans-code {
    background: #f0eee8;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.8rem 1rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--text);
    margin: 0.6rem 0;
    overflow-x: auto;
  }
  .ans-code .c-kw  { color: #c0392b; font-weight: 700; }
  .ans-code .c-fn  { color: #6f42c1; }
  .ans-code .c-str { color: #0d7a5f; }
  .ans-code .c-cm  { color: #999; font-style: italic; }
  .ans-code .c-num { color: #0550ae; }

  /* BADGES */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Space Mono', monospace;
    font-size: 0.62rem;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .badge-green { background: rgba(13,158,126,0.1); color: var(--accent3); border: 1px solid rgba(13,158,126,0.25); }
  .badge-purple { background: rgba(79,70,229,0.1); color: var(--accent1); border: 1px solid rgba(79,70,229,0.25); }
  .badge-pink { background: rgba(224,64,94,0.1); color: var(--accent2); border: 1px solid rgba(224,64,94,0.25); }
  .badge-orange { background: rgba(201,122,26,0.1); color: var(--accent4); border: 1px solid rgba(201,122,26,0.25); }

  /* CALLOUT */
  .callout {
    display: flex;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border-radius: 12px;
    margin: 1rem 0;
    font-size: 0.87rem;
    line-height: 1.6;
  }

  .callout-warning {
    background: rgba(201,122,26,0.08);
    border-left: 3px solid var(--accent4);
    color: var(--text);
  }

  .callout-info {
    background: rgba(79,70,229,0.07);
    border-left: 3px solid var(--accent1);
    color: var(--text);

<script>
  /* ============================================================
     KEYWORD DATABASE
  ============================================================ */
  const KW_DATA = {
    'Entité type': {
      def: 'Une <strong>entité type</strong> est la représentation abstraite d\'une catégorie d\'objets du monde réel partageant les mêmes caractéristiques. C\'est le "moule" à partir duquel on crée des instances.',
      ex: 'ÉTUDIANT, VOITURE, COURS',
      tip: 'Ne pas confondre avec une occurrence : ÉTUDIANT est l\'entité type, "Marie Curie n°345" est une occurrence.'
    },
    'Occurrence': {
      def: 'Une <strong>occurrence</strong> (ou instance) est un exemplaire concret d\'une entité type. Elle correspond à une ligne dans la future table SQL.',
      ex: 'Étudiant n°345 : Marie Curie, née 1967',
      tip: 'Chaque occurrence est unique, identifiée par son identifiant.'
    },
    'Association': {
      def: 'Une <strong>association</strong> représente un lien sémantique entre deux ou plusieurs entités. Elle se nomme avec un verbe à l\'infinitif et peut porter ses propres attributs.',
      ex: 'ÉTUDIANT — "suit" → COURS\n(avec attribut : note, semestre)',
      tip: 'Si l\'association porte des attributs, elle deviendra une table en MLD (règle N-N).'
    },
    'Cardinalité (min, max)': {
      def: 'La <strong>cardinalité</strong> exprime le nombre minimum et maximum de fois qu\'une entité participe à une association. Format : (min, max).',
      ex: 'CLIENT (1,N) — passer — COMMANDE (1,1)\n→ Un client passe 1 à N commandes',
      tip: 'min=0 = participation optionnelle, min=1 = obligatoire. Lire la cardinalité côté entité opposée.'
    },
    'Identifiant': {
      def: 'L\'<strong>identifiant</strong> est l\'attribut qui permet d\'identifier de manière unique chaque occurrence d\'une entité. Il est souligné dans le MCD.',
      ex: 'ÉTUDIANT : numEtudiant (souligné)',
      tip: 'L\'identifiant devient la PRIMARY KEY en SQL. Il doit être unique et non nul.'
    },
    'Attribut multivalué': {
      def: 'Un <strong>attribut multivalué</strong> peut contenir plusieurs valeurs pour une même occurrence. Il viole la 1FN et doit être transformé en une entité séparée.',
      ex: 'Un LIVRE avec plusieurs AUTEURS\n→ créer l\'entité AUTEUR séparée',
      tip: '⚠️ Interdit en base de données finale. Toujours transformer en entité + association.'
    },
    'Attribut dérivé': {
      def: 'Un <strong>attribut dérivé</strong> est calculable à partir d\'autres données déjà stockées. Il ne doit PAS être stocké car il crée de la redondance.',
      ex: 'âge = calculé depuis dateNaissance\n→ stocker uniquement dateNaissance',
      tip: '⚠️ Ne jamais stocker un attribut dérivé. Le calculer à la volée dans les requêtes SQL.'
    },
    '1FN / 2FN / 3FN': {
      def: 'Les <strong>Formes Normales</strong> garantissent la qualité du modèle.\n1FN : attributs atomiques + identifiant.\n2FN : dépendances fonctionnelles élémentaires.\n3FN : dépendances uniquement depuis l\'identifiant.',
      ex: '3FN : VOITURE(Immatriculation, Type, Marque)\nMarque dépend de Type → violation 3FN',
      tip: 'En pratique : chaque attribut doit dépendre uniquement de la clé primaire, toute la clé, rien d\'autre.'
    },
    'Dépendance fonctionnelle': {
      def: 'A → B signifie que la valeur de A détermine <strong>uniquement</strong> la valeur de B. C\'est la base du raisonnement sur les formes normales.',
      ex: 'numEtudiant → nomEtudiant (OK)\nType → Marque dans VOITURE (violation 3FN)',
      tip: 'Pour la 3FN, seul l\'identifiant doit être à gauche de la flèche de dépendance.'
    },
    'Association réflexive': {
      def: 'Une <strong>association réflexive</strong> lie une entité à elle-même. Ex : un Employé a un supérieur qui est aussi un Employé.',
      ex: 'EMPLOYE(idEmploye, nom, idSuperviseur FK → EMPLOYE)',
      tip: 'En MLD, une seule table avec un attribut auto-référençant (FK vers sa propre table).'
    },
    'Clé Primaire (PK)': {
      def: 'La <strong>clé primaire</strong> (PRIMARY KEY) identifie de manière unique chaque ligne d\'une table. Elle est NOT NULL et UNIQUE par définition.',
      ex: 'CREATE TABLE student(\n  std_id INT PRIMARY KEY\n)',
      tip: 'Correspond à l\'identifiant du MCD. Une table n\'a qu\'une seule PK (mais elle peut être composite).'
    },
    'Clé Étrangère (FK)': {
      def: 'La <strong>clé étrangère</strong> (FOREIGN KEY) est un attribut qui référence la clé primaire d\'une autre table, matérialisant ainsi un lien entre tables.',
      ex: 'FOREIGN KEY (unv_name)\n  REFERENCES university(unv_name)',
      tip: 'La FK est le résultat de la migration de clé lors de la transformation MCD → MLD (règle 1-N).'
    },
    'NOT NULL': {
      def: '<strong>NOT NULL</strong> est une contrainte qui interdit les valeurs nulles pour un attribut. Elle garantit que la colonne aura toujours une valeur.',
      ex: 'std_name VARCHAR(30) NOT NULL',
      tip: 'Une FK est NOT NULL quand la cardinalité minimum est 1 côté de l\'entité qui porte la FK.'
    },
    'UNIQUE': {
      def: '<strong>UNIQUE</strong> garantit que toutes les valeurs d\'une colonne sont distinctes. Indispensable pour les FK dans les associations 1-1.',
      ex: 'numCommande FK UNIQUE NOT NULL\n→ garantit 1 seule facture par commande',
      tip: 'Différent de PRIMARY KEY : une table peut avoir plusieurs contraintes UNIQUE, mais une seule PK.'
    },
    'Clé composite': {
      def: 'Une <strong>clé composite</strong> est une clé primaire formée de plusieurs attributs. Elle est utilisée dans les tables de jointure issues d\'associations N-N.',
      ex: 'CONTIENT(\n  numCommande FK,\n  reference FK,\n  PK = (numCommande, reference)\n)',
      tip: 'C\'est le résultat direct de la règle 2 (N-N) du passage MCD → MLD.'
    },
    'Migration de clé': {
      def: 'La <strong>migration de clé</strong> est le mécanisme par lequel la PK d\'une entité "migre" vers une autre table sous forme de FK lors du passage en MLD.',
      ex: 'UNIVERSITÉ (PK: nomUniv)\n→ ÉTUDIANT reçoit nomUniv comme FK',
      tip: 'En règle 1-N : la PK du côté "1" migre vers le côté "N".'
    },
    "Contrainte d'intégrité": {
      def: 'Les <strong>contraintes d\'intégrité</strong> garantissent la cohérence des données : NOT NULL, UNIQUE, CHECK, FOREIGN KEY.',
      ex: 'On ne peut pas supprimer une université\nsi des étudiants la référencent encore.',
      tip: 'MySQL vérifie les contraintes automatiquement. DROP TABLE sur une table référencée → erreur !'
    },
    'Règle 1-N / N-N / 1-1': {
      def: 'Les <strong>3 règles de transformation</strong> MCD→MLD :\n1-N : FK migre côté N\nN-N : association → table avec PK composite\n1-1 : FK avec UNIQUE côté dépendant',
      ex: '1-N : ÉTUDIANT reçoit FK de UNIVERSITÉ\nN-N : CONTIENT(FK1, FK2)\n1-1 : FACTURE reçoit FK de COMMANDE UNIQUE',
      tip: 'La cardinalité maximale des deux côtés détermine la règle : regarder si c\'est 1 ou N de chaque côté.'
    },
    'VARCHAR(n)': {
      def: '<strong>VARCHAR(n)</strong> stocke des chaînes de caractères de longueur variable. n définit le nombre maximum de caractères.',
      ex: 'std_name VARCHAR(30)\nunv_country VARCHAR(20)',
      tip: 'Utiliser VARCHAR plutôt que CHAR sauf si la longueur est toujours fixe (ex: codes postaux).'
    },
    'INT / DECIMAL': {
      def: '<strong>INT</strong> stocke des entiers. <strong>DECIMAL(p,s)</strong> stocke des nombres exacts avec p chiffres au total et s après la virgule.',
      ex: 'std_id INT\nprix DECIMAL(10,2)  -- ex: 9999999.99',
      tip: 'Ne jamais utiliser FLOAT pour les prix ! DECIMAL garantit la précision exacte.'
    },
    'PRIMARY KEY': {
      def: '<strong>PRIMARY KEY</strong> déclare l\'identifiant unique d\'une table. Combinaison automatique de NOT NULL + UNIQUE.',
      ex: 'std_id INT NOT NULL PRIMARY KEY\n-- PK composite :\nPRIMARY KEY (col1, col2)',
      tip: 'Pour une PK composite (N-N), on la déclare après les colonnes : PRIMARY KEY (fk1, fk2).'
    },
    'FOREIGN KEY': {
      def: '<strong>FOREIGN KEY</strong> lie une colonne à la PK d\'une autre table. Elle garantit l\'intégrité référentielle.',
      ex: 'FOREIGN KEY (unv_name)\n  REFERENCES university(unv_name)',
      tip: 'La table parent (référencée) doit être créée AVANT la table enfant. Sinon erreur !'
    },
    'REFERENCES': {
      def: '<strong>REFERENCES</strong> indique quelle table et quelle colonne est ciblée par une FOREIGN KEY.',
      ex: 'FOREIGN KEY (cat_id)\n  REFERENCES categorie(cat_id)',
      tip: 'La colonne référencée doit être PRIMARY KEY ou avoir une contrainte UNIQUE dans sa table.'
    },
    'CREATE TABLE': {
      def: '<strong>CREATE TABLE</strong> crée une nouvelle table dans la base de données avec ses colonnes, types et contraintes.',
      ex: 'CREATE TABLE student(\n  std_id INT PRIMARY KEY,\n  std_name VARCHAR(30) NOT NULL\n);',
      tip: 'Ordre crucial : créer les tables parents avant les tables enfants qui les référencent.'
    },
    'INSERT INTO VALUES': {
      def: '<strong>INSERT INTO ... VALUES</strong> ajoute des lignes dans une table. On peut insérer plusieurs lignes en une seule commande.',
      ex: "INSERT INTO university VALUES\n  ('PSB', 'France', 'Paris'),\n  ('UTT', 'France', 'Troyes');",
      tip: 'L\'ordre des valeurs doit correspondre exactement à l\'ordre des colonnes de la table.'
    },
    'UPDATE SET WHERE': {
      def: '<strong>UPDATE ... SET ... WHERE</strong> modifie des données existantes. SET définit les nouvelles valeurs, WHERE cible les lignes.',
      ex: "UPDATE university\nSET unv_address = 'Lyon'\nWHERE unv_name = 'PSB';",
      tip: '⚠️ Sans WHERE, TOUTES les lignes sont modifiées ! Toujours vérifier le WHERE avant d\'exécuter.'
    },
    'ALTER TABLE ADD': {
      def: '<strong>ALTER TABLE ADD</strong> ajoute une nouvelle colonne à une table existante sans la supprimer ni recréer.',
      ex: 'ALTER TABLE student\nADD std_age INTEGER;',
      tip: 'On peut aussi modifier (MODIFY) ou supprimer (DROP COLUMN) des colonnes avec ALTER TABLE.'
    },
    'DROP TABLE': {
      def: '<strong>DROP TABLE</strong> supprime définitivement une table et toutes ses données. Irréversible !',
      ex: '-- Ordre obligatoire :\nDROP TABLE student;    -- enfant d\'abord\nDROP TABLE university; -- parent ensuite',
      tip: '⚠️ On ne peut pas supprimer une table si d\'autres tables la référencent en FK.'
    },
    'SELECT FROM': {
      def: '<strong>SELECT</strong> choisit les colonnes à afficher. <strong>FROM</strong> indique la table source. Structure de base de toute requête de lecture.',
      ex: 'SELECT title, length FROM film;\nSELECT * FROM customer;',
      tip: 'SELECT * affiche toutes les colonnes. Préférer lister les colonnes explicitement en production.'
    },
    'WHERE': {
      def: '<strong>WHERE</strong> filtre les lignes selon une ou plusieurs conditions. Les lignes ne satisfaisant pas la condition sont exclues.',
      ex: "SELECT title FROM film\nWHERE rating = 'PG'\n  AND length > 100;",
      tip: 'WHERE filtre les LIGNES avant GROUP BY. Pour filtrer des groupes, utiliser HAVING.'
    },
    'ORDER BY ASC/DESC': {
      def: '<strong>ORDER BY</strong> trie les résultats. <strong>ASC</strong> = ordre croissant (défaut), <strong>DESC</strong> = ordre décroissant.',
      ex: 'SELECT title FROM film\nORDER BY title ASC;\nORDER BY length DESC;',
      tip: 'On peut trier sur plusieurs colonnes : ORDER BY col1 DESC, col2 ASC'
    },
    'LIMIT': {
      def: '<strong>LIMIT n</strong> restreint le nombre de lignes retournées. Utile pour les aperçus et les top-N.',
      ex: 'SELECT * FROM film\nORDER BY length DESC\nLIMIT 10;',
      tip: 'Toujours utiliser ORDER BY avec LIMIT pour des résultats déterministes.'
    },
    'DISTINCT': {
      def: '<strong>SELECT DISTINCT</strong> élimine les doublons dans les résultats. Chaque combinaison de valeurs n\'apparaît qu\'une seule fois.',
      ex: 'SELECT DISTINCT rating FROM film;\n-- Retourne : PG, G, R, PG-13, NC-17',
      tip: 'DISTINCT s\'applique à toute la ligne sélectionnée, pas seulement à une colonne.'
    },
    'COUNT / SUM / AVG': {
      def: '<strong>COUNT(*)</strong> compte les lignes. <strong>SUM(col)</strong> additionne les valeurs. <strong>AVG(col)</strong> calcule la moyenne.',
      ex: 'SELECT COUNT(*) FROM film;\nSELECT SUM(amount) FROM payment;\nSELECT AVG(length) FROM film;',
      tip: 'COUNT(*) compte toutes les lignes. COUNT(col) ignore les NULL dans cette colonne.'
    },
    'MAX / MIN': {
      def: '<strong>MAX(col)</strong> retourne la valeur maximale. <strong>MIN(col)</strong> retourne la valeur minimale.',
      ex: 'SELECT MAX(length) FROM film;\nSELECT MIN(rental_rate) FROM film;',
      tip: 'Combinable avec GROUP BY pour trouver le max/min par groupe.'
    },
    'GROUP BY': {
      def: '<strong>GROUP BY</strong> regroupe les lignes ayant les mêmes valeurs, permettant d\'appliquer des fonctions d\'agrégation à chaque groupe.',
      ex: 'SELECT rating, COUNT(*) AS nb\nFROM film\nGROUP BY rating\nORDER BY nb DESC;',
      tip: 'Règle d\'or : toute colonne dans SELECT sans fonction d\'agrégation DOIT être dans GROUP BY.'
    },
    'LIKE % et _': {
      def: '<strong>LIKE</strong> filtre selon un motif textuel. <strong>%</strong> = n\'importe quelle séquence de caractères. <strong>_</strong> = exactement un caractère.',
      ex: "WHERE title LIKE 'A%'     -- commence par A\nWHERE title LIKE '%love%'  -- contient love\nWHERE title LIKE '_AT%'   -- 2e lettre = A",
      tip: 'LIKE est insensible à la casse en MySQL par défaut.'
    },
    'BETWEEN AND': {
      def: '<strong>BETWEEN a AND b</strong> filtre les valeurs comprises entre a et b, bornes incluses.',
      ex: 'WHERE length BETWEEN 90 AND 120\nWHERE rental_rate BETWEEN 1.00 AND 3.00',
      tip: 'Les bornes sont INCLUSES. Fonctionne aussi sur les dates.'
    },
    'IS NULL / IS NOT NULL': {
      def: '<strong>IS NULL</strong> vérifie si une valeur est absente. <strong>IS NOT NULL</strong> vérifie qu\'une valeur est présente.',
      ex: 'WHERE email IS NOT NULL\nWHERE email IS NULL',
      tip: '⚠️ WHERE col = NULL ne fonctionne PAS. Toujours IS NULL ou IS NOT NULL.'
    },
    'AND / OR': {
      def: '<strong>AND</strong> exige que TOUTES les conditions soient vraies. <strong>OR</strong> exige qu\'AU MOINS UNE condition soit vraie.',
      ex: "WHERE rating = 'PG' AND length > 100\nWHERE rating = 'G' OR rating = 'PG'",
      tip: 'AND est prioritaire sur OR. Utiliser des parenthèses pour lever toute ambiguïté : (A OR B) AND C'
    }
  };

  /* ============================================================
     MODULE DECKS
  ============================================================ */
  const MODULE_DECKS = {
    mcd: ['Entité type','Occurrence','Association','Cardinalité (min, max)','Identifiant','Attribut multivalué','Attribut dérivé','1FN / 2FN / 3FN','Dépendance fonctionnelle','Association réflexive'],
    mld: ['Clé Primaire (PK)','Clé Étrangère (FK)','NOT NULL','UNIQUE','Clé composite','Migration de clé',"Contrainte d'intégrité",'Règle 1-N / N-N / 1-1'],
    mpd: ['VARCHAR(n)','INT / DECIMAL','PRIMARY KEY','FOREIGN KEY','REFERENCES','NOT NULL','CREATE TABLE','INSERT INTO VALUES','UPDATE SET WHERE','ALTER TABLE ADD','DROP TABLE'],
    sql: ['SELECT FROM','WHERE','ORDER BY ASC/DESC','LIMIT','DISTINCT','COUNT / SUM / AVG','MAX / MIN','GROUP BY','LIKE % et _','BETWEEN AND','IS NULL / IS NOT NULL','AND / OR']
  };
  const MODULE_NAMES = {
    mcd: 'Module 01 — MCD',
    mld: 'Module 02 — MLD',
    mpd: 'Module 03 — MPD & MySQL',
    sql: 'Module 04 — Requêtes SQL'
  };

  /* ============================================================
     FLASHCARD STATE
  ============================================================ */
  let fcDeck = [], fcIndex = 0, fcFlipped = false, fcSeenSet = new Set(), fcCurrentModule = '';

  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  /* ============================================================
     ALL PUBLIC FUNCTIONS (override stubs from <head>)
  ============================================================ */
  window.startFlashcards = function(module) {
    fcCurrentModule = module;
    fcDeck = shuffle(MODULE_DECKS[module]);
    fcIndex = 0;
    fcSeenSet = new Set();
    fcFlipped = false;
    document.getElementById('fcDeckInfo').textContent = MODULE_NAMES[module];
    document.getElementById('fcFinish').style.display = 'none';
    document.getElementById('fcScene').style.display = 'block';
    document.getElementById('fcDots').style.display = 'flex';
    document.getElementById('fcNav').style.display = 'flex';
    renderFcDots();
    renderFcCard();
    document.getElementById('fcOverlay').classList.add('visible');
    document.body.style.overflow = 'hidden';
  };

  window.closeFlashcards = function() {
    document.getElementById('fcOverlay').classList.remove('visible');
    document.body.style.overflow = '';
  };

  window.restartFlashcards = function() {
    window.startFlashcards(fcCurrentModule);
  };

  window.flipCard = function() {
    fcFlipped = !fcFlipped;
    document.getElementById('fcCard').classList.toggle('flipped', fcFlipped);
    if (fcFlipped) { fcSeenSet.add(fcIndex); renderFcDots(); }
  };

  window.fcNext = function() {
    if (!document.getElementById('fcOverlay').classList.contains('visible')) return;
    fcSeenSet.add(fcIndex);
    if (fcIndex < fcDeck.length - 1) {
      fcIndex++;
      renderFcCard();
    } else {
      showFcFinish();
    }
  };

  window.fcPrev = function() {
    if (!document.getElementById('fcOverlay').classList.contains('visible')) return;
    if (fcIndex > 0) { fcIndex--; renderFcCard(); }
  };

  window.closeKwModal = function() {
    document.getElementById('kwModal').classList.remove('visible');
    document.body.style.overflow = '';
  };

  window.closeModal = function(e) {
    if (e.target === document.getElementById('kwModal')) window.closeKwModal();
  };

  /* ============================================================
     INTERNAL HELPERS
  ============================================================ */
  function renderFcCard() {
    const term = fcDeck[fcIndex];
    const data = KW_DATA[term];
    document.getElementById('fcFrontTerm').textContent = term;
    document.getElementById('fcBackDef').innerHTML = data ? data.def.replace(/\n/g, '<br>') : '—';
    document.getElementById('fcBackEx').innerHTML = data ? (data.ex || '').replace(/\n/g, '<br>') : '';
    document.getElementById('fcProgressText').textContent = (fcIndex + 1) + ' / ' + fcDeck.length;
    document.getElementById('fcCard').classList.remove('flipped');
    fcFlipped = false;
    document.getElementById('fcPrevBtn').style.opacity = fcIndex === 0 ? '0.35' : '1';
    const isLast = fcIndex === fcDeck.length - 1;
    const nextBtn = document.getElementById('fcNextBtn');
    nextBtn.textContent = isLast ? '🎉 Terminer' : 'Suivant →';
    nextBtn.className = isLast ? 'fc-btn fc-btn-finish' : 'fc-btn fc-btn-next';
    renderFcDots();
  }

  function renderFcDots() {
    const container = document.getElementById('fcDots');
    container.innerHTML = '';
    fcDeck.forEach(function(_, i) {
      const dot = document.createElement('div');
      dot.className = 'fc-dot' + (fcSeenSet.has(i) ? ' seen' : '') + (i === fcIndex ? ' current' : '');
      container.appendChild(dot);
    });
  }

  function showFcFinish() {
    document.getElementById('fcScene').style.display = 'none';
    document.getElementById('fcDots').style.display = 'none';
    document.getElementById('fcNav').style.display = 'none';
    document.getElementById('fcFinishSub').textContent =
      'Tu as parcouru les ' + fcDeck.length + ' concepts du ' + MODULE_NAMES[fcCurrentModule] + '. Relance pour t\'entraîner encore !';
    document.getElementById('fcFinish').style.display = 'block';
  }

  /* ============================================================
     EVENT DELEGATION — keyword chips (works on hidden sections)
  ============================================================ */
  document.body.addEventListener('click', function(e) {
    const chip = e.target.closest('.kw-chip');
    if (!chip) return;
    const term = chip.dataset.kw;
    const data = KW_DATA[term];
    if (!data) return;
    document.getElementById('modalTerm').textContent = term;
    document.getElementById('modalDef').innerHTML = data.def.replace(/\n/g, '<br>');
    document.getElementById('modalExCode').innerHTML = (data.ex || '').replace(/\n/g, '<br>');
    document.getElementById('modalTip').innerHTML = '💡 ' + (data.tip || '');
    document.getElementById('kwModal').classList.add('visible');
    document.body.style.overflow = 'hidden';
  });

  /* ============================================================
     KEYBOARD SHORTCUTS
  ============================================================ */
  document.addEventListener('keydown', function(e) {
    const modalOpen = document.getElementById('kwModal').classList.contains('visible');
    const fcOpen    = document.getElementById('fcOverlay').classList.contains('visible');
    if (e.key === 'Escape') {
      if (modalOpen) window.closeKwModal();
      else if (fcOpen) window.closeFlashcards();
    }
    if (!fcOpen) return;
    if (e.key === 'ArrowRight') window.fcNext();
    if (e.key === 'ArrowLeft')  window.fcPrev();
    if (e.key === ' ') { e.preventDefault(); window.flipCard(); }
  });
</script>

</body>
</html>

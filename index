  <div class="section-header">
    <div class="section-tag" style="--accent:#c97a1a">Module 04</div>
    <h2 class="section-title">Requêtes <span style="color:var(--accent4)">SQL</span></h2>
    <p class="section-intro">On travaille sur une base de location de films (~1000 films) avec les tables : film, customer, payment, inventory, actor, staff. Toutes les requêtes s'écrivent sur papier à l'examen.</p>
  </div>

  <!-- SELECT DE BASE -->
  <div class="card">
    <div class="card-title">1️⃣ SELECT — La base de tout</div>

    <div class="query-breakdown">
      <div class="qb-line">
        <span class="qb-kw">SELECT</span>
        <span class="qb-val">colonne1, colonne2</span>
        <span class="qb-note">ou * pour tout afficher</span>
      </div>
      <div class="qb-line">
        <span class="qb-kw">FROM</span>
        <span class="qb-val">nom_table</span>
        <span class="qb-note">table source</span>
      </div>
      <div class="qb-line" style="opacity:0.5">
        <span class="qb-kw">WHERE</span>
        <span class="qb-val">condition</span>
        <span class="qb-note">optionnel</span>
      </div>
      <div class="qb-line" style="opacity:0.5">
        <span class="qb-kw">ORDER BY</span>
        <span class="qb-val">colonne ASC/DESC</span>
        <span class="qb-note">optionnel</span>
      </div>
      <div class="qb-line" style="opacity:0.5">
        <span class="qb-kw">LIMIT</span>
        <span class="qb-val">n</span>
        <span class="qb-note">optionnel</span>
      </div>
    </div>

    <div class="code-block">
      <div class="code-label">Exemples pratiques</div>
<span class="cm">-- Tous les titres de films</span>
<span class="kw">SELECT</span> title <span class="kw">FROM</span> film<span class="str">;</span>

<span class="cm">-- ID, nom, prénom, email des clients</span>
<span class="kw">SELECT</span> customer_id, last_name, first_name, email
<span class="kw">FROM</span> customer<span class="str">;</span>

<span class="cm">-- Films par ordre alphabétique inverse</span>
<span class="kw">SELECT</span> title <span class="kw">FROM</span> film
<span class="kw">ORDER BY</span> title <span class="fn">DESC</span><span class="str">;</span>

<span class="cm">-- Les 10 premiers films</span>
<span class="kw">SELECT</span> * <span class="kw">FROM</span> film <span class="kw">LIMIT</span> <span class="num">10</span><span class="str">;</span>
    </div>
  </div>

  <!-- WHERE -->
  <div class="card">
    <div class="card-title">2️⃣ WHERE — Filtrer les résultats</div>
    <table class="rules-table">
      <tr><th>Opérateur</th><th>Signification</th><th>Exemple</th></tr>
      <tr><td>=</td><td>Égal</td><td>WHERE rating = 'PG'</td></tr>
      <tr><td>!=</td><td>Différent</td><td>WHERE rating != 'R'</td></tr>
      <tr><td>&gt; / &lt;</td><td>Supérieur / Inférieur</td><td>WHERE rental_rate &gt; 2.99</td></tr>
      <tr><td>&gt;= / &lt;=</td><td>Sup ou égal / Inf ou égal</td><td>WHERE length &gt;= 90</td></tr>
      <tr><td>AND</td><td>Les deux conditions vraies</td><td>WHERE rating = 'PG' AND length &gt; 100</td></tr>
      <tr><td>OR</td><td>Au moins une vraie</td><td>WHERE rating = 'PG' OR rating = 'G'</td></tr>
      <tr><td>LIKE '%x%'</td><td>Contient x</td><td>WHERE title LIKE '%love%'</td></tr>
      <tr><td>BETWEEN a AND b</td><td>Entre a et b inclus</td><td>WHERE length BETWEEN 60 AND 120</td></tr>
      <tr><td>IS NULL / IS NOT NULL</td><td>Valeur nulle ou non</td><td>WHERE email IS NOT NULL</td></tr>
    </table>

    <div class="code-block">
      <div class="code-label">Exemples</div>
<span class="cm">-- Films dont le titre contient "LOVE"</span>
<span class="kw">SELECT</span> title <span class="kw">FROM</span> film
<span class="kw">WHERE</span> title <span class="fn">LIKE</span> <span class="str">'%LOVE%'</span><span class="str">;</span>

<span class="cm">-- Films de durée entre 90 et 120 min</span>
<span class="kw">SELECT</span> title, length <span class="kw">FROM</span> film
<span class="kw">WHERE</span> length <span class="fn">BETWEEN</span> <span class="num">90</span> <span class="fn">AND</span> <span class="num">120</span><span class="str">;</span>

<span class="cm">-- Clients avec email</span>
<span class="kw">SELECT</span> first_name, last_name <span class="kw">FROM</span> customer
<span class="kw">WHERE</span> email <span class="fn">IS NOT NULL</span><span class="str">;</span>
    </div>
  </div>

  <!-- FONCTIONS D'AGRÉGATION -->
